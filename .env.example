# Radix configuration — copy to .env and adjust. See SPEC §10.

# --- Domain / TLS (Caddy) ---
RADIX_DOMAIN=localhost

# --- Database ---
POSTGRES_USER=radix
POSTGRES_PASSWORD=change-me
POSTGRES_DB=radix

# --- LLM (SPEC §2, §10) ---
# Runtime switch (set by deploy/install.sh):
#   bundled  → Ollama runs inside the stack. install.sh adds docker-compose.llm.yml to
#              COMPOSE_FILE below and pulls LLM_MODEL. GPU is used automatically when the
#              NVIDIA Container Toolkit is present (docker-compose.gpu.yml), else CPU.
#   external → Ollama/vLLM managed outside the stack; point LLM_BASE_URL at it. No LLM
#              container is started and no model is pulled.
LLM_RUNTIME=bundled
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:9b-instruct-q4_K_M
# bundled → http://ollama:11434/v1 · external → your endpoint (e.g. http://192.168.1.10:11434/v1)
LLM_BASE_URL=http://ollama:11434/v1

# --- Compose wiring (managed by deploy/install.sh — edit only if you know why) ---
# Docker Compose reads COMPOSE_FILE from .env automatically, so `docker compose up -d`
# assembles the right stack with no -f flags.
#   external           → docker-compose.yml
#   bundled (CPU)      → docker-compose.yml:docker-compose.llm.yml
#   bundled (GPU)      → docker-compose.yml:docker-compose.llm.yml:docker-compose.gpu.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.llm.yml

# --- Pipeline ---
EMBED_DEVICE=auto
OCR_LANGS=ita+eng+deu
SYNC_INTERVAL_MIN=5
# Calibrated in M4 on the eval set; stored in the settings table once tuned.
# REFUSAL_THRESHOLD=

# --- Storage ---
DATA_DIR=./data
# Host folder mounted at /data/sources inside api and worker: folder sources (type
# local/smb) must point to paths under /data/sources. Mount SMB shares below it.
SOURCES_DIR=./data/sources

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me
# First-boot admin (created only if no user exists yet)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
